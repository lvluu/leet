{
  "root": "./docs",
  "title": "Coding Patterns Guide",
  "description": "Free comprehensive guide to common coding patterns for algorithmic problems. Based on Grokking the Coding Interview by DesignGurus.io",
  "author": "lvluu",
  "language": "en",
  "gitbook": ">=3.2.3",
  "structure": {
    "readme": "README.md",
    "summary": "SUMMARY.md"
  },
  "plugins": [
    "theme-comscore",
    "github",
    "edit-link",
    "-highlight",
    "prism",
    "prism-themes",
    "copy-code-button",
    "splitter",
    "search-plus",
    "anchorjs",
    "expandable-chapters-small",
    "page-toc-button",
    "back-to-top-button",
    "-lunr",
    "-search",
    "-sharing"
  ],
  "pluginsConfig": {
    "theme-comscore": {
      "showLevel": true
    },
    "prism": {
      "lang": {
        "python": "python",
        "js": "javascript",
        "typescript": "typescript",
        "java": "java",
        "cpp": "cpp"
      },
      "css": ["prism-themes/themes/prism-one-light.css"]
    },
    "github": {
      "url": "https://github.com/lvluu/leet"
    },
    "edit-link": {
      "base": "https://github.com/lvluu/leet/edit/main",
      "label": "✏️ Edit"
    },
    "search-plus": {
      "depth": 3,
      "maxLength": 10000
    },
    "page-toc-button": {
      "maxTocDepth": 2,
      "minTocSize": 2
    },
    "sharing": false
  },
  "styles": {
    "website": "styles/website.css"
  }
}
